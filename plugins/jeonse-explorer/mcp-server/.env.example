# ACTIGENCE Jeonse Explorer MCP Server 환경 변수
# 본 파일을 .env로 복사하고 실제 값을 입력하세요.

# === Supabase (정적 데이터 DB) ===
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_KEY=YOUR_SERVICE_KEY  # 빌드 시 데이터 적재용 (클라이언트 노출 X)

# === Anthropic API (선택 — 분포 해설 텍스트 생성용) ===
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY  # CPN 파트너십 활용

# === MCP 서버 설정 ===
MCP_PORT=3001
MCP_BASE_URL=https://jeonse-explorer.actigence.ai
NODE_ENV=production

# === 컴플라이언스 설정 ===
ENABLE_PII_GUARDRAIL=true              # 가해자 정보 정규식 차단 (기본 활성화)
ENABLE_COMPLIANCE_LOG=true              # 컴플라이언스 차단 이벤트 로깅 (개인정보 X, 패턴만)
MAX_REQUESTS_PER_IP_PER_MINUTE=10       # rate limiting

# === 모니터링 (선택) ===
SENTRY_DSN=
VERCEL_ANALYTICS_ID=
